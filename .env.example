# ────────────────────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────────────────────
PORT="3000"
# Public base URL of this backend (no trailing slash). Used to derive the SAML
# SP entity ID and ACS URL when they are not set explicitly. On Railway this is
# the public service domain, e.g. https://zu-metaverse-backend-staging.up.railway.app
PUBLIC_BASE_URL="http://localhost:3000"

# ────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL / Drizzle)
# ────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:@localhost:5432/metaverse"
# Set to "false" to skip running migrations automatically on boot.
RUN_MIGRATIONS_ON_BOOT="true"

# ────────────────────────────────────────────────────────────────────────────
# Access token (JWT issued after a successful SSO login)
# ────────────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="86400" # seconds (24h)

# ────────────────────────────────────────────────────────────────────────────
# SAML SSO
# ────────────────────────────────────────────────────────────────────────────
SAML_ENABLED="true"

# Identity Provider (Zayed University ADFS)
SAML_IDP_ENTITY_ID="http://wsso.zu.ac.ae/adfs/services/trust"
SAML_IDP_SSO_URL="https://wsso.zu.ac.ae/adfs/ls/"
SAML_IDP_METADATA_URL="https://wsso.zu.ac.ae/FederationMetadata/2007-06/FederationMetadata.xml"
# Optional: PEM (or single-line base64) signing cert used only if the metadata
# URL is unreachable and nothing is cached in the database.
SAML_IDP_CERT=""

# Service Provider (this backend). If left empty these are derived from
# PUBLIC_BASE_URL as:
#   SAML_SP_ENTITY_ID = ${PUBLIC_BASE_URL}/api/V1/auth/saml/metadata
#   SAML_SP_ACS_URL   = ${PUBLIC_BASE_URL}/api/V1/auth/saml/acs
SAML_SP_ENTITY_ID=""
SAML_SP_ACS_URL=""
# Optional SP signing key/cert (PEM, "\n" escapes allowed) to sign AuthnRequests.
SAML_SP_PRIVATE_KEY=""
SAML_SP_CERT=""

# Claim URIs (defaults shown are the ADFS standard claim types)
SAML_CLAIM_EMAIL="http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress"
SAML_CLAIM_NAME="http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"
SAML_CLAIM_UPN="http://schemas.xmlsoap.org/ws/2005/05/identity/claims/upn"
# Optional: a stable per-user identifier claim (preferred over UPN/NameID if set).
SAML_CLAIM_STUDENT_ID=""

# Where to send the user after a successful assertion. The one-time exchange
# code is appended as ?code=... Set this to the frontend /sso/callback URL.
SAML_SUCCESS_REDIRECT_URL="https://zu-metaverse-staging.vercel.app/sso/callback"
# Comma-separated hostnames allowed as RelayState targets.
SAML_ALLOWED_RELAY_HOSTS="zu-metaverse-staging.vercel.app,localhost"

# Tuning / debugging
SAML_CLOCK_SKEW_MS="30000"
SAML_DEBUG_CLAIMS="false"
